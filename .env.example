# NeuroUI environment variables
# Copy this file to .env.local and fill in your values

# ── Required ────────────────────────────────────────────────────────────────
CURSOR_API_KEY=your_cursor_api_key_here

# ── Supabase (persistent /g/[id] sharing — falls back to in-memory without these) ──
# Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Project Settings → API → Project API keys → publishable
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxx
# Optional: service_role key for elevated privileges (bypasses RLS)
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
